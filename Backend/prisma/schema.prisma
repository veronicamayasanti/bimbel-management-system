generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Admin {
  id        String  @id @default(uuid())
  username  String
  password  String
  full_name String?

  created_at DateTime @default(now())
  isActive   Boolean  @default(true)
  created_by String?
}

model User {
  id        String  @id @default(uuid())
  full_name String
  email     String  @unique
  password  String
  telp_no   String?
  address   String?

  created_at DateTime @default(now())
  isActive   Boolean  @default(true)
  created_by String?
}
