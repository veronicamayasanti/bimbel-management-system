generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Admin {
  id        String  @id @default(uuid())
  username  String  @unique
  password  String
  full_name String?
  avatar    String? @default("avatar_default.png")

  created_at  DateTime      @default(now())
  isActive    Boolean       @default(true)
  created_by  String?
  Transaction Transaction[]
}

model User {
  id                   String    @id @default(uuid())
  full_name            String
  email                String    @unique
  password             String
  telp_no              String?
  address              String?
  resetPasswordToken   String?
  resetPasswordExpires DateTime?
  avatar               String?   @default("avatar_default.png")

  created_at DateTime @default(now())
  isActive   Boolean  @default(true)
  created_by String?

  students Student[]
}

model Branch {
  id         Int      @id @default(autoincrement())
  name       String
  address    String   @db.Text
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  students           Student[]
  recurringSchedules RecurringSchedule[]
  lessonSchedules    LessonSchedule[]
}

model Program {
  id          Int      @id @default(autoincrement())
  name        String
  description String   @db.Text
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  packages           ProgramPackage[]
  schedules          LessonSchedule[]
  recurringSchedules RecurringSchedule[]
}

model Level {
  id         Int      @id @default(autoincrement())
  name       String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  students           Student[]
  recurringSchedules RecurringScheduleLevel[]
}

model Student {
  id         Int    @id @default(autoincrement())
  parentId   String
  branchId   Int
  levelId    Int
  fullName   String
  schoolName String

  // Relations
  parent User   @relation(fields: [parentId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  level  Level  @relation(fields: [levelId], references: [id], onDelete: Cascade)

  transactions    Transaction[]
  studentPackages StudentPackage[]
  attendances     Attendance[]
  recurringSchedules RecurringScheduleStudent[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

enum PaymentMethod {
  TRANSFER
  CASH
}

enum PaymentStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum PackageStatus {
  ACTIVE
  EXPIRED
}

model ProgramPackage {
  id            Int      @id @default(autoincrement())
  programId     Int
  name          String
  totalMeetings Int
  price         Decimal  @db.Decimal(10, 2)
  isActive      Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)

  transactions    Transaction[]
  studentPackages StudentPackage[]
}

model Transaction {
  id               String        @id @default(uuid())
  studentId        Int
  programPackageId Int
  amount           Decimal       @db.Decimal(10, 2)
  paymentMethod    PaymentMethod
  paymentProof     String?
  paymentStatus    PaymentStatus @default(PENDING)
  notes            String?       @db.Text

  verifiedById String?
  verifiedAt   DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  student        Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  programPackage ProgramPackage @relation(fields: [programPackageId], references: [id])
  verifiedBy     Admin?         @relation(fields: [verifiedById], references: [id])

  studentPackage StudentPackage?
}

model StudentPackage {
  id               Int    @id @default(autoincrement())
  studentId        Int
  programPackageId Int
  transactionId    String @unique

  totalMeetings     Int
  remainingMeetings Int
  status            PackageStatus @default(ACTIVE)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  student        Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  programPackage ProgramPackage @relation(fields: [programPackageId], references: [id])
  transaction    Transaction    @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  attendances    Attendance[]
}

model Teacher {
  id         Int      @id @default(autoincrement())
  fullName   String
  email      String   @unique
  password   String
  telpNo     String?
  avatar     String?  @default("avatar_default.png")
  isActive   Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  schedules LessonSchedule[]
  recurring RecurringSchedule[]
}

model RecurringSchedule {
  id          Int      @id @default(autoincrement())
  teacherId   Int
  programId   Int
  branchId    Int?
  dayOfWeek   Int      // 0-6 (Sunday-Saturday)
  startTime   String   // "HH:mm"
  endTime     String   // "HH:mm"
  isActive    Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  teacher  Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  program  Program  @relation(fields: [programId], references: [id])
  branch   Branch?  @relation(fields: [branchId], references: [id])
  students RecurringScheduleStudent[]
  levels   RecurringScheduleLevel[]
}

model RecurringScheduleLevel {
  id                  Int               @id @default(autoincrement())
  recurringScheduleId Int
  levelId             Int
  
  recurringSchedule   RecurringSchedule @relation(fields: [recurringScheduleId], references: [id], onDelete: Cascade)
  level               Level             @relation(fields: [levelId], references: [id], onDelete: Cascade)

  @@unique([recurringScheduleId, levelId])
}

model RecurringScheduleStudent {
  id                  Int               @id @default(autoincrement())
  recurringScheduleId Int
  studentId           Int
  
  recurringSchedule   RecurringSchedule @relation(fields: [recurringScheduleId], references: [id], onDelete: Cascade)
  student             Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([recurringScheduleId, studentId])
}

model LessonSchedule {
  id          Int      @id @default(autoincrement())
  teacherId   Int
  programId   Int
  branchId    Int?
  date        DateTime
  startTime   DateTime
  endTime     DateTime
  status      String   @default("SCHEDULED") // SCHEDULED, COMPLETED, CANCELLED
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  teacher     Teacher      @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  program     Program      @relation(fields: [programId], references: [id])
  branch      Branch?       @relation(fields: [branchId], references: [id])
  attendances Attendance[]
}

model Attendance {
  id               Int      @id @default(autoincrement())
  scheduleId       Int
  studentId        Int
  studentPackageId Int
  status           String   @default("PENDING") // PENDING, PRESENT, ABSENT, PERMIT
  notes            String?  @db.Text
  markedAt         DateTime?
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  schedule       LessonSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  student        Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentPackage StudentPackage @relation(fields: [studentPackageId], references: [id], onDelete: Cascade)

  @@unique([scheduleId, studentId])
}
