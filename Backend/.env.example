# ========================================
# Bimbel Management System - Environment
# ========================================

# Database (Prisma)
DATABASE_URL=mysql://user:password@localhost:3306/bimbel_db

# JWT Secret (Ganti dengan string acak yang panjang)
JWT_SECRET=your_jwt_secret_here_change_this

# Server
PORT=3000

# Frontend URL (Untuk CORS dan link reset password)
FRONTEND_URL=http://localhost:5173

# Email (Untuk fitur Lupa Password)
# Gunakan Ethereal untuk development: https://ethereal.email
EMAIL_HOST=smtp.ethereal.email
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
